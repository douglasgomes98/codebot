{
  "name": "codebot",
  "displayName": "Codebot - Code generator by templates",
  "description": "This extension creates automated codes based on custom created templates.",
  "version": "2.0.1",
  "icon": "assets/codebot.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/douglasgomes98/codebot"
  },
  "publisher": "douglasgomes98",
  "license": "MIT",
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Codebot",
      "properties": {
        "codebot.templatesFolderPath": {
          "type": "string",
          "default": "templates",
          "scope": "resource",
          "markdownDescription": "Path to the templates folder, relative to the workspace root."
        },
        "codebot.templateSettings": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "markdownDescription": "Per-template settings. Keys must match template folder names.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "nameFormat": {
                "type": "string",
                "enum": [
                  "pascal-case",
                  "kebab-case",
                  "camel-case",
                  "snake-case"
                ],
                "enumDescriptions": [
                  "MyComponent (default)",
                  "my-component",
                  "myComponent",
                  "my_component"
                ],
                "default": "pascal-case",
                "description": "How the component name is formatted when generating files."
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "commands": [
      {
        "command": "codebot.createComponent",
        "title": "✨ Build Template"
      },
      {
        "command": "codebot.updateComponent",
        "title": "🔁 Update Template"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "codebot.createComponent",
          "group": "1_modification",
          "when": "explorerResourceIsFolder"
        },
        {
          "command": "codebot.updateComponent",
          "group": "1_modification",
          "when": "explorerResourceIsFolder"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build": "vsce package",
    "lint": "biome check --error-on-warnings . --write",
    "lint:check": "biome check --error-on-warnings .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "semantic-release": "semantic-release",
    "dev-install": "npm run compile && vsce package && code --install-extension codebot-$(node -p \"require('./package.json').version\").vsix --force"
  },
  "engines": {
    "vscode": "^1.100.0",
    "node": ">=24.12.0"
  },
  "dependencies": {
    "handlebars": "^4.7.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "24.x",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.9.0",
    "git-commit-msg-linter": "^5.0.8",
    "jest": "^30.3.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^5.8.2",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
